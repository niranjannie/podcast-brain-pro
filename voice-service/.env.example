# ===========================================
# Podcast Brain Pro - Environment Config
# ===========================================
# Copy this file to .env and fill in your keys.
# At least one LLM provider is required for script generation.

# --- Primary Script Provider (Recommended) ---
DIALOGRAM_API_KEY=

# --- Fallback Script Providers ---
GITHUB_PERSONAL_ACCESS_TOKEN=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=

# --- Optional: Indian Language TTS ---
SARVAM_API_KEY=

# --- Optional: Live Web Research ---
TAVILY_API_KEY=

# --- Optional: Override default paths ---
# VOICES_DIR=../vibevoice-src/demo/voices/streaming_model
# LONGFORM_VOICES_DIR=../vibevoice-src/demo/voices
# OUTPUT_DIR=./outputs

# --- Optional: Move HuggingFace model cache (models are large!) ---
# HF_HOME=/path/to/larger/disk/.cache/huggingface

# --- Optional: Preload ASR on startup ---
# ASR_PRELOAD_AT_STARTUP=false

# --- Optional: Tune Longform TTS for your hardware ---
# Lower DDPM steps = faster generation, slightly lower quality (default: 5)
# LONGFORM_DDPM_STEPS=5
# Smaller chunks = less RAM usage, more stitching gaps (default: 350 on MPS, 300 on CPU)
# MAX_LONGFORM_WORDS_MPS=350
# MAX_LONGFORM_WORDS_CPU=300
